# Copy to `.env` (gitignored) and fill in real values.
# Never commit real tokens.

# --- Mapbox ---
# Secret token (sk.*) used by the Python pipeline to upload tilesets, styles, etc.
# Required scopes: UPLOADS:*, TILESETS:*, STYLES:WRITE/LIST + default public scopes.
MAPBOX_SECRET_TOKEN=

# Public token (pk.*) used by the web app. URL-restricted once deployed.
# Required scopes: STYLES:TILES, STYLES:READ, FONTS:READ, DATASETS:READ (defaults).
MAPBOX_PUBLIC_TOKEN=

# Mapbox username (the account that owns the tokens / tilesets / styles).
MAPBOX_USERNAME=

# --- Optional: data source credentials ---
# Most Italian public data sources are anonymous, but some (e.g. Copernicus,
# CMEMS) require an account. Leave blank if not used.
COPERNICUS_USER=
COPERNICUS_PASSWORD=
CMEMS_USER=
CMEMS_PASSWORD=
