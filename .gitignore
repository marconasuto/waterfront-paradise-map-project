# --- data ---
# Raw and intermediate data are produced by acquisition/processing pipelines.
# Large binaries should not be committed; the data catalog (config/layers.yaml,
# data/catalog.yaml) is authoritative about what files exist and where.
data/raw/**
data/interim/**
data/processed/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/catalog.yaml
!data/publish_manifest.yaml

# common geo binaries
*.tif
*.tiff
*.cog
*.mbtiles
*.pmtiles
*.gpkg-journal
*.gpkg-wal
*.gpkg-shm

