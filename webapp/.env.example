# Copy to `webapp/.env` (gitignored) and fill in real values.
# Only `VITE_*` vars are exposed to the browser by Vite.

# Mapbox public token (pk.*). URL-restrict it in the Mapbox dashboard
# once the site is deployed. Required scopes: STYLES:TILES, STYLES:READ,
# FONTS:READ, DATASETS:READ (defaults). Generate at:
#   https://account.mapbox.com/access-tokens/
VITE_MAPBOX_PUBLIC_TOKEN=
