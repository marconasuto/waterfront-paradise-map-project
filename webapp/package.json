{
  "name": "manfredonia-map-webapp",
  "version": "0.0.1",
  "private": true,
  "description": "Vite + TypeScript storymap for the Manfredonia coastal map.",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-config.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-config.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mapbox-gl": "^3.6.0",
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@types/mapbox-gl": "^3.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "yaml": "^2.5.0"
  }
}
